{
  "openapi": "3.0.0",
  "info": { "title": "Circular Ref Test", "version": "1.0.0" },
  "servers": [{ "url": "http://localhost" }],
  "paths": {
    "/nodes": {
      "get": {
        "operationId": "listNodes",
        "summary": "List all nodes",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Node" }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createNode",
        "summary": "Create a node",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Node" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Node" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Node": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "parent": { "$ref": "#/components/schemas/Node" },
          "children": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Node" }
          }
        }
      }
    }
  }
}
